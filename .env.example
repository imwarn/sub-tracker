# Telegram 通知配置
# 获取 Bot Token: 跟 @BotFather 创建 bot
# 获取 Chat ID: 跟 @userinfobot 发消息获取
TG_BOT_TOKEN=
TG_CHAT_ID=

# 推送通道选择
# DEFAULT_NOTIFY_CHANNEL: all / telegram / bark / wecom / webhook
# 未设置或 all = 普通提醒发送到全部已配置渠道
DEFAULT_NOTIFY_CHANNEL=all

# 登录验证码通道：telegram / bark / wecom / webhook
# 留空时：若 DEFAULT_NOTIFY_CHANNEL 是单一通道则沿用；否则优先 Telegram，再取首个已配置通道
AUTH_NOTIFY_CHANNEL=

# 可选：Bark 推送（二选一；BARK_URL 优先）
BARK_KEY=
BARK_URL=
BARK_SERVER=https://api.day.app

# 可选：企业微信机器人
WECOM_WEBHOOK_URL=
# 兼容旧变量名
WECHAT_WORK_WEBHOOK_URL=

# 可选：通用 Webhook
WEBHOOK_URL=
